#!/bin/sh
set -eu
SUBJECT=$(grep -v '^#' "$1" | grep -v '^[[:space:]]*$' | head -1)
if ! echo "$SUBJECT" | grep -qE '^(feat|fix|chore|docs|style|refactor|test|ci|build|perf|revert)(\(.+\))?: .+'; then
  echo "ERROR: Commit message must follow Conventional Commits."
  echo "  Example: feat: add user login"
  echo "  Types: feat|fix|chore|docs|style|refactor|test|ci|build|perf|revert"
  exit 1
fi
